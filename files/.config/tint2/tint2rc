# Panel items:
panel_items = LTSC

panel_position = bottom center horizontal
panel_size = 100% 40
panel_background_id = 1

rounded = 0
border_width = 1

# Background definitions (Windows 10 taskbar dark theme)
rounded = 0
border_width = 1
background_color = #2B2B2B FF
border_color = #3A3A3A FF

# Launcher ("Start")
launcher_item_app = ~/.local/share/applications/start.desktop
launcher_padding = 10 10 10

# Tasks (Windows-like spacing)
task_centered = 0
task_icon = 1
task_text = 1
task_maximum_size = 180 36

# Task text colors (Windows 10 style)
task_font_color = #FFFFFF FF
task_active_font_color = #FFFFFF FF

# Systray
systray_padding = 6 6 6

# Clock (Windows-like spacing)
time1_format = %H:%M
time2_format = %d.%m.%Y
clock_padding = 10 6
clock_font_color = #FFFFFF FF

# Launcher icon tint
launcher_icon_theme_override = 1

# Panel foreground items
font_color = #FFFFFF 100
