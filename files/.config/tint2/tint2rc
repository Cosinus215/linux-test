# Panel
panel_items = LTC
panel_position = bottom center horizontal
panel_size = 100% 40
panel_margin = 0 0
panel_padding = 0 4
panel_background_id = 1

# Background 1 - Entire taskbar background
rounded = 0
border_width = 1
background_color = #2B2B2B
border_color = #3A3A3A

# Background 2 - Task buttons (inactive)
rounded = 0
border_width = 0
background_color = #3D3D3D
border_color = #3D3D3D

# Background 3 - Task buttons (active/hover)
rounded = 0
border_width = 0
background_color = #505050
border_color = #505050

# Launcher ("Start")
launcher_item_app = ~/.local/share/applications/start.desktop
launcher_padding = 10 6 6

# Tasks
task_centered = 0
task_icon = 1
task_text = 1
task_maximum_size = 180 36
task_font_color = #FFFFFF
task_active_font_color = #FFFFFF
task_background_id = 2
task_active_background_id = 3

# Clock
time1_format = %H:%M
time2_format = %d.%m.%Y
clock_padding = 8 6
clock_font_color = #FFFFFF

# Launcher icon tint
launcher_icon_theme_override = 1
